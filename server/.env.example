# Secret used to sign login sessions (JWT). Generate a long random string for production —
# e.g. `openssl rand -hex 32` — and never reuse the dev default below.
JWT_SECRET=dev-secret-change-me-in-production

# Port the API listens on.
PORT=4000

# Stripe (subscription billing). Leave empty to keep billing disabled (checkout returns
# a clear "not configured" error instead of crashing). Get these from your Stripe dashboard:
# https://dashboard.stripe.com/apikeys and https://dashboard.stripe.com/webhooks
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Public URL of the frontend, used for Stripe checkout redirect links.
APP_URL=http://localhost:5173
